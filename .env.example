# Banco principal Desenrola (tenants, customers, message_logs, reservations...)
DESENROLA_DB_URL=postgresql://user:pass@host:5432/desenrola

# Banco workflow_processor (workflow_definitions, workflow_executions, execution_step_logs)
WORKFLOW_PROCESSOR_DB_URL=postgresql://user:pass@host:5432/workflow_processor

# Google Chat webhook pra notificações de monitor (opcional — sem isso só loga)
GOOGLE_CHAT_WEBHOOK=

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Em prod (Railway), setar NODE_ENV=production pra desligar pino-pretty
NODE_ENV=development

# DeepSeek (usado pelo DailyReportsJob — chama LLM pra gerar relatório por tenant)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DAILY_REPORTS_DEEPSEEK_MODEL=deepseek-v4-flash

# Quantas conversas amostrar por bucket (conversion/handoff/no-conversion).
# Cada conversa vai com até 50 mensagens — 100 amostras consomem ~900k tokens de input.
DAILY_REPORTS_CONVERSATION_SAMPLES_N=100
